<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.9.dtd">

<suite name="E-Commerce Automation Suite" verbose="1">

    <test name="Login Tests">
        <classes>
            <class name="com.ecommerce.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Registration Tests">
        <classes>
            <class name="com.ecommerce.tests.RegistrationTest"/>
        </classes>
    </test>

    <test name="Product Search Tests">
        <classes>
            <class name="com.ecommerce.tests.ProductSearchTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.ecommerce.tests.CartTest"/>
        </classes>
    </test>

    <test name="Checkout Tests">
        <classes>
            <class name="com.ecommerce.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>