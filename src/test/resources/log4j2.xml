<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!--
        Log4j2 Configuration File
        Controls WHERE logs go and WHAT FORMAT they use.

        Two appenders defined:
        1. Console → prints to terminal during test run
        2. File    → saves to logs/ folder permanently
    -->

    <Appenders>

        <!-- CONSOLE APPENDER: prints logs to terminal -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <!--
                Pattern breakdown:
                %d{HH:mm:ss.SSS} → timestamp like 10:05:23.456
                [%t]             → thread name
                %-5level         → log level (INFO, WARN, ERROR) padded to 5 chars
                %logger{36}      → class name (max 36 chars)
                %msg             → your actual log message
                %n               → newline
            -->
        </Console>

        <!-- FILE APPENDER: saves logs to a file -->
        <RollingFile name="FileAppender"
                     fileName="logs/automation.log"
                     filePattern="logs/automation_%d{yyyy-MM-dd}_%i.log">
            <!--
                RollingFile automatically creates new log files
                when the current one gets too big.
                Prevents one massive log file.
            -->
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <!-- Roll over daily -->
                <TimeBasedTriggeringPolicy interval="1"/>
                <!-- Roll over when file exceeds 10MB -->
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <!-- Keep maximum 30 log files -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

    </Appenders>

    <Loggers>
        <!-- Root logger: catches ALL log messages -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Root>

        <!-- Framework logger: DEBUG level for our code only -->
        <!-- This means our classes log more detail than third-party libs -->
        <Logger name="com.ecommerce" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>
    </Loggers>

</Configuration>